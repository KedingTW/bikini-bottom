# 🏝️ 比奇堡開發團隊 — 環境變數範本
# 複製此檔案為 .env 並填入實際值

# Bot Tokens（每個角色一個 Discord Application）
DISCORD_BOT_TOKEN_BOB=
DISCORD_BOT_TOKEN_PATRICK=
DISCORD_BOT_TOKEN_PUFF=
DISCORD_BOT_TOKEN_GARY=
DISCORD_BOT_TOKEN_SQUIDWARD=

# Channel IDs
CHANNEL_GENERAL=
KIRO_USAGE_CHANNEL_ID=

# Slash Bot 設定
DISCORD_GUILD_ID=
SLASH_BOT_CHANNEL_ID=

# Git / GitHub
GIT_EMAIL=
GH_TOKEN=

# GitHub PAT（所有角色共用，用於 gh CLI 操作）
GH_TOKEN=

# AWS（slash-bot 查詢 Athena 用）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Kiro CLI API Keys
KIRO_API_KEY_BOB=你的key
KIRO_API_KEY_PATRICK=你的key
KIRO_API_KEY_PUFF=你的key
KIRO_API_KEY_SQUIDWARD=你的key
KIRO_API_KEY_GARY=你的key

# Redmine MCP（POC）
REDMINE_URL=
REDMINE_API_KEY_BOB=
