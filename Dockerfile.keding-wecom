# 科定WeCom — Agent Image
# 精簡版：只含 git，不含 gh CLI / pandoc / Python 文件套件
# Image tag: keding-wecom/agent:latest

FROM ghcr.io/openabdev/openab:0.8.4
USER root

RUN apt-get update && apt-get install -y --no-install-recommends git && rm -rf /var/lib/apt/lists/*

COPY scripts/entrypoint-keding-wecom.sh /usr/local/bin/entrypoint-keding-wecom.sh
RUN chmod +x /usr/local/bin/entrypoint-keding-wecom.sh

ENTRYPOINT ["/usr/local/bin/entrypoint-keding-wecom.sh"]
